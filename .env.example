# ==============================================================================
# Environment Configuration Template — Invoice Processing Agent
# ==============================================================================

# Google Gemini API key — obtain one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB connection string — docker-compose maps this to the container name
# For Docker Compose, the default is: mongodb://mongo:27017/invoiceDB
MONGO_URI=mongodb://mongo:27017/invoiceDB
